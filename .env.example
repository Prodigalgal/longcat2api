# Server
PORT=8080
HOST=0.0.0.0

# Data (K8s: /var/lib/longcat2api)
DATA_DIR=./data
CONFIG_PATH=./data/config.json
SQLITE_PATH=./data/longcat2api.db

# Auth (K8s Secret also accepts LONGCAT2API_* prefix)
LONGCAT2API_API_KEYS=sk-longcat
LONGCAT2API_ADMIN_PASSWORD=admin
LONGCAT2API_DEFAULT_MODE=session
LONGCAT2API_KEEPALIVE_INTERVAL_SECONDS=21600

# Optional: temp mail / proxy (usually only in K8s Secret)
# LONGCAT2API_TEMP_MAIL_API_BASE=
# LONGCAT2API_TEMP_MAIL_ADMIN_PASSWORD=
# LONGCAT2API_PROXY_ENABLED=false
# LONGCAT2API_PROXY_SUB_URL=

# Register timeouts (ms) — LongCat/mykeeta are slow
# LONGCAT2API_REGISTER_TIMEOUT_MS=420000
# LONGCAT2API_REG_GOTO_MS=120000
# LONGCAT2API_REG_OTP_UI_MS=90000
# LONGCAT2API_REGISTER_OTP_TIMEOUT=240

# AI captcha — LAST RESORT only (OpenAI-compatible vision)
# LONGCAT2API_CAPTCHA_AI_ENABLED=false
# LONGCAT2API_CAPTCHA_AI_API_BASE=https://sub2api.example.com
# LONGCAT2API_CAPTCHA_AI_API_KEY=sk-xxx
# LONGCAT2API_CAPTCHA_AI_MODEL=grok
# LONGCAT2API_CAPTCHA_AI_TIMEOUT=90
